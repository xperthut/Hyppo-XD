# ─── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json      # regenerated; commit only if you pin exact deps

# ─── C++ native addon (node-gyp) ──────────────────────────────────────────────
app/build/
app/bin/
app/src/Makefile
app/binding.Makefile
app/config.gypi
app/gyp-mac-tool
app/*.target.mk
app/node_gyp_bins/
**/*.o
**/*.a
**/*.so
**/*.dylib
**/*.node

# ─── Hyppo-XD temp / generated files ─────────────────────────────────────────
app/src/view/wp.sp
app/src/view/tmp.sp
app/src/view/mapper.html   # generated at runtime from template

# ─── Electron packager output ─────────────────────────────────────────────────
app/release-builds/
app/release/

# ─── Electron user-data cache (dev runs) ──────────────────────────────────────
app/Hyppo-XD-darwin-*/
app/Hyppo-XD-linux-*/
app/Hyppo-XD-win32-*/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Linux ────────────────────────────────────────────────────────────────────
*~
.nfs*

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
.project
.classpath
